{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "python3 -m http.server \"${PORT:-8010}\""],
      "port": 8010,
      "autoPort": true
    },
    {
      "name": "cloudflare-pages",
      "runtimeExecutable": "wrangler",
      "runtimeArgs": ["pages", "dev", ".", "--port", "8788"],
      "port": 8788
    }
  ]
}
