    <h1 class="page-title reveal reveal-delay-1">Experience</h1>

    <div class="exp-list">

      <!-- Dialectica -->
      <div class="exp-entry card reveal reveal-delay-1">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">
              Dialectica
              <span class="exp-present-badge">Present</span>
            </h2>
            <p class="exp-role">Senior Product Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Oct 2023 – Present</span>
            <span class="exp-location">Greece</span>
          </div>
        </div>
      </div>

      <!-- Sensora -->
      <div class="exp-entry card reveal reveal-delay-2">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">Sensora</h2>
            <p class="exp-role">Product Designer · Co-Founder</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Sep 2022 – Nov 2024</span>
            <span class="exp-location">United States</span>
          </div>
        </div>
        <div class="exp-body">
          <p>As co-founder and product designer at our IoT startup, I was responsible for driving the overall design strategy across our digital platforms, ensuring a seamless user experience and visually compelling interface.</p>
          <p>I actively contributed to business strategy discussions, helping shape the product roadmap and identify key features, combining design skills with a deep understanding of our target market to foster the startup's growth.</p>
        </div>
      </div>

      <!-- PNOĒ -->
      <div class="exp-entry card reveal reveal-delay-2">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">PNOĒ</h2>
            <p class="exp-role">Design System Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Apr 2022 – Oct 2023</span>
            <span class="exp-location">Greece</span>
          </div>
        </div>
        <div class="exp-body">
          <ul class="exp-bullets">
            <li>Developed and maintained the Design System.</li>
            <li>Created a design token strategy, complex components and patterns.</li>
          </ul>
        </div>
      </div>

      <!-- Skroutz -->
      <div class="exp-entry card reveal reveal-delay-3">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">Skroutz</h2>
            <p class="exp-role">Senior Product Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Apr 2021 – Apr 2023</span>
            <span class="exp-location">Athens, Greece</span>
          </div>
        </div>
        <div class="exp-body">
          <ul class="exp-bullets">
            <li>Influenced the design team's adoption of Figma as primary tool, eliminating redundant tooling. Created a 10-step visual guide with best practices, resulting in a 50% reduction in file transition time from Sketch.</li>
            <li>Designed a savings visualisation feature for Skroutz Plus, the subscription programme. Resulted in a 2% increase in Plus subscriptions.</li>
          </ul>
        </div>
      </div>

      <!-- Beat -->
      <div class="exp-entry card reveal reveal-delay-3">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">Beat</h2>
            <p class="exp-role">Product Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Aug 2017 – Apr 2021</span>
            <span class="exp-location">Greece</span>
          </div>
        </div>
        <div class="exp-body">
          <ul class="exp-bullets">
            <li>Designed the "Bonuses" feature for the Driver app, a dedicated incentives screen informed by user interviews. Increased driver engagement by +63% and total rides completed by +2%.</li>
            <li>Built a dashboard for the Data Science team to create custom incentives without manual database entry. After one round of usability testing, the feature increased incentive creation speed by 50% and reduced data entry errors by 70%.</li>
          </ul>
        </div>
      </div>

      <!-- Tripsta -->
      <div class="exp-entry card reveal reveal-delay-4">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">Tripsta</h2>
            <p class="exp-role">Web Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Jun 2016 – Aug 2017</span>
          </div>
        </div>
      </div>

      <!-- Another Circus -->
      <div class="exp-entry card reveal reveal-delay-4">
        <div class="exp-entry-header">
          <div>
            <h2 class="exp-company">Another Circus Creative Agency</h2>
            <p class="exp-role">Junior Graphic Designer</p>
          </div>
          <div class="exp-meta">
            <span class="exp-dates">Jun 2014 – Sep 2014</span>
          </div>
        </div>
        <div class="exp-body">
          <div class="exp-tags">
            <span class="exp-tag">UI Design</span>
            <span class="exp-tag">Web Design</span>
            <span class="exp-tag">Logo Design</span>
          </div>
        </div>
      </div>

    </div>
