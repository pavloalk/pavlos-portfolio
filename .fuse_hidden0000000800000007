  <style>
    /* ── Page Header ── */
    .page-label {
      font-size: var(--font-small);
      font-weight: 400;
      color: var(--text-secondary);
      margin-bottom: var(--space-12);
    }

    .page-title {
      font-size: var(--font-h1);
      font-weight: 700;
      line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--text-primary);
      margin-bottom: var(--space-48);
    }

    /* ── Experience List ── */
    .exp-list {
      display: flex;
      flex-direction: column;
      gap: var(--space-8);
    }

    /* ── Entry Card (pairs with .card in markup) ── */
    .exp-entry-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: var(--space-16);
    }

    .exp-company {
      font-size: var(--font-h3);
      font-weight: 700;
      color: var(--text-primary);
      letter-spacing: -0.02em;
      line-height: 1.3;
      display: flex;
      align-items: center;
      gap: var(--space-8);
      flex-wrap: wrap;
    }

    .exp-present-badge {
      font-size: var(--font-badge);
      font-weight: 500;
      color: var(--text-secondary);
      background: var(--present-bg);
      border-radius: var(--radius-pill);
      padding: var(--space-2) var(--space-10);
      letter-spacing: 0;
      white-space: nowrap;
    }

    .exp-role {
      font-size: var(--font-small);
      font-weight: 500;
      color: var(--text-body);
      margin-top: var(--space-4);
      line-height: 1.4;
    }

    .exp-meta {
      text-align: right;
      flex-shrink: 0;
    }

    .exp-dates {
      font-size: var(--font-caption);
      font-weight: 400;
      color: var(--text-secondary);
      display: block;
      line-height: 1.4;
      white-space: nowrap;
    }

    .exp-location {
      font-size: var(--font-tag);
      font-weight: 400;
      color: var(--text-secondary);
      display: block;
      margin-top: var(--space-2);
      opacity: 0.7;
    }

    /* ── Entry Body ── */
    .exp-body {
      margin-top: var(--space-16);
      padding-top: var(--space-16);
      border-top: 1px solid var(--border-entry);
    }

    .exp-body p {
      font-size: var(--font-small);
      font-weight: 400;
      line-height: 1.7;
      color: var(--text-body);
    }

    .exp-body p + p {
      margin-top: var(--space-12);
    }

    /* ── Bullet List ── */
    .exp-bullets {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-10);
    }

    .exp-bullets li {
      font-size: var(--font-small);
      font-weight: 400;
      line-height: 1.7;
      color: var(--text-body);
      padding-left: var(--space-16);
      position: relative;
    }

    .exp-bullets li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--text-secondary);
      font-weight: 600;
    }

    /* ── Skill Tags ── */
    .exp-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-6);
      margin-top: var(--space-12);
    }

    .exp-tag {
      font-size: var(--font-tag);
      font-weight: 500;
      color: var(--text-secondary);
      background: var(--tag-bg);
      border-radius: var(--radius-pill);
      padding: var(--space-4) var(--space-12);
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .exp-entry-header {
        flex-direction: column;
        gap: var(--space-6);
      }

      .exp-meta {
        text-align: left;
      }
    }
